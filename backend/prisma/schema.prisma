generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Todo {
  id          Int       @id @default(autoincrement())
  title       String
  description String?   // <-- ADD THIS
  priority    Priority  @default(MEDIUM)
  tags        String[]
  dueDate     DateTime?
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  NONE
}